# ----------------------------
# ⚙️ DJANGO CONFIGURATION
# ----------------------------
DEBUG=True  # Set to False in production
SECRET_KEY=your-secret-key-here  # Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Comma-separated list of allowed hosts (local + public)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# ----------------------------
# 🛢 DATABASE CONFIGURATION
# ----------------------------

# ✅ LOCAL/DOCKER DATABASE (Default - Development)
DB_NAME=afridata
DB_USER=afriuser
DB_PASSWORD=strong_password
DB_HOST=db  # For Docker Compose use `db`; for local use `127.0.0.1`
DB_PORT=3306

# 🔒 OPTIONAL - CLOUD DB (e.g. Amazon RDS)
# Uncomment and update for production DB connection
# DB_NAME=afridata
# DB_USER=produser
# DB_PASSWORD=super_secure_prod_password
# DB_HOST=your-rds-host.amazonaws.com
# DB_PORT=3306

# Render/Heroku/Railway-style platforms (used by dj_database_url)
# RENDER=true
# DATABASE_URL=mysql://afriuser:strong_password@your-host/dbname

# ----------------------------
# 🤖 AI / LLM CONFIGURATION
# ----------------------------

# Active backend: gemini | openai | anthropic | ollama
LLM_BACKEND=gemini
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=4096

# Google Gemini API (default backend)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional - set LLM_BACKEND=openai to use)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (optional - set LLM_BACKEND=anthropic to use)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (optional - set LLM_BACKEND=ollama for local models)
# OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------
# 📲 M-PESA CONFIGURATION
# ----------------------------
# Sandbox or Production Callback URL — must be HTTPS!
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback/

# Optional advanced settings (if using separate credentials)
# MPESA_CONSUMER_KEY=your_consumer_key
# MPESA_CONSUMER_SECRET=your_consumer_secret
# MPESA_SHORTCODE=your_shortcode
# MPESA_PASSKEY=your_passkey

# ----------------------------
# ☁️ CLOUD & STORAGE (optional)
# ----------------------------

# AWS (if using S3 for media/model files — set MODEL_STORE_BACKEND=s3)
# MODEL_STORE_BACKEND=s3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
# AWS_REGION=us-east-1

# Optional: Sentry error tracking
# SENTRY_DSN=https://xxx.ingest.sentry.io/xxx

# ----------------------------
# 🚀 DEPLOYMENT OVERRIDES
# ----------------------------

# Used to prevent env loading in CI/CD (optional)
# GITHUB_ACTIONS=true

# Superuser auto-creation via entrypoint.sh
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
# DJANGO_SUPERUSER_PASSWORD=strong_admin_password
